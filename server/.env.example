# Database
DATABASE_URL=postgresql+psycopg2://localhost:5432/ecosphere

# Security
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Uploads
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=5

# Email (optional; in-app notifications work without this)
MAIL_ENABLED=false
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@ecosphere.local
MAIL_SERVER=smtp.mailtrap.io
MAIL_PORT=587
