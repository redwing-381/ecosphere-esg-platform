# Database
DATABASE_URL=postgresql+psycopg2://localhost:5432/ecosphere

# Security
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Uploads
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=5
# Set (or auto-injected by Vercel) to store proof files in Vercel Blob.
# When empty, files are written to the local UPLOAD_DIR instead.
BLOB_READ_WRITE_TOKEN=

# CORS: comma-separated browser origins allowed to call the API.
# In production set this to your frontend Vercel URL.
CORS_ORIGINS=http://localhost:5173

# Email (optional; in-app notifications work without this)
MAIL_ENABLED=false
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@ecosphere.local
MAIL_SERVER=smtp.mailtrap.io
MAIL_PORT=587
